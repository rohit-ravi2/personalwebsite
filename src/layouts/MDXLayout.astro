---
import ContentTags from "../components/ContentTags.astro";
import IndexPageLayout from "./IndexPageLayout.astro";

const { frontmatter } = Astro.props;
const { title, description, image, startDate, tags, canonical } = frontmatter;

const isProject = Astro.url.pathname.startsWith("/projects/");
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const toIso = (d: unknown): string | undefined => {
  if (!d) return undefined;
  if (d instanceof Date) return d.toISOString().slice(0, 10);
  if (typeof d === "string") return d;
  return undefined;
};

const imageUrl = image?.url
  ? (image.url.startsWith("http")
      ? image.url
      : new URL(image.url, Astro.site).toString())
  : new URL("/og-image.png", Astro.site).toString();

const articleSchema = isProject
  ? {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      headline: title,
      name: title,
      description,
      datePublished: toIso(startDate),
      dateModified: toIso(startDate),
      author: {
        "@type": "Person",
        name: "Rohit Ravi",
        url: "https://www.rohitravi.com",
      },
      publisher: {
        "@type": "Person",
        name: "Rohit Ravi",
        url: "https://www.rohitravi.com",
      },
      image: imageUrl,
      keywords: (tags ?? []).join(", "),
      url: pageUrl,
      mainEntityOfPage: pageUrl,
      inLanguage: "en-US",
      isAccessibleForFree: true,
    }
  : null;
---

<IndexPageLayout title={title} description={description} image={image} subTitle={title} canonicalURL={canonical}>
  <div class="w-full justify-center flex flex-col">
    {tags &&
      <div class="pb-4 mx-auto">
        <ContentTags tags={tags}/>
      </div>}

    {startDate &&
      <div class="text-sm text-light my-2 sr-only mx-auto">
        {startDate}
      </div>
    }

    <article class="prose mx-auto">
      <slot/>
    </article>
  </div>

  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}
</IndexPageLayout>
