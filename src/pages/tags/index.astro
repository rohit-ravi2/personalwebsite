---
import { getAndGroupUniqueTags } from "../../lib/utils";
import IndexPageLayout from "../../layouts/IndexPageLayout.astro";

const tagsMap = await getAndGroupUniqueTags();

type Entry = { value: string; count: number };

const tagsWithFrequency: Entry[] = [];
tagsMap.forEach((value, key) => {
  tagsWithFrequency.push({ value: key, count: value.length });
});

// Alphabetical order for the primary grid; also keep a top-N ranking.
const alphabetical = [...tagsWithFrequency].sort((a, b) =>
  a.value.localeCompare(b.value),
);
const top = [...tagsWithFrequency]
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

const maxCount = Math.max(...tagsWithFrequency.map((t) => t.count), 1);
---
<IndexPageLayout
  title="Tags"
  description="Every tag used across projects, experience, certifications, and books — click one to see everything under it."
  subTitle="Tags"
>
  <div class="flex flex-col gap-10">
    {/* Most-used */}
    <section>
      <h2 class="text-lg font-semibold mb-3">Most used</h2>
      <ul class="flex flex-wrap gap-2">
        {top.map((tag) => (
          <li>
            <a
              href={`/tags/${tag.value}`}
              class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium hover:border-primary hover:bg-accent hover:text-accent-foreground transition-colors"
            >
              <span>{tag.value}</span>
              <span class="text-xs text-muted-foreground tabular-nums">{tag.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* Full alphabetical grid */}
    <section>
      <h2 class="text-lg font-semibold mb-3">
        All tags <span class="text-sm text-muted-foreground">· {tagsWithFrequency.length}</span>
      </h2>
      <ul class="flex flex-wrap gap-2">
        {alphabetical.map((tag) => {
          // Scale text size subtly by frequency so the grid has texture.
          const weight = tag.count / maxCount;
          const size = weight > 0.66 ? "text-base" : weight > 0.33 ? "text-sm" : "text-xs";
          return (
            <li>
              <a
                href={`/tags/${tag.value}`}
                class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 font-medium hover:border-primary hover:bg-accent hover:text-accent-foreground transition-colors ${size}`}
              >
                <span>{tag.value}</span>
                <span class="text-xs text-muted-foreground tabular-nums">{tag.count}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  </div>
</IndexPageLayout>
