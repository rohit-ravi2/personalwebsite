---
import { getEntryBySlug } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;
const book = await getEntryBySlug("books", slug);
if (!book) throw new Error(`Book not found: ${slug}`);
---

<BaseLayout title={book.data.title} description={book.data.title}>
  <article class="prose mx-auto p-6">
    <h1 class="text-3xl font-bold">{book.data.title}</h1>
    <p class="text-lg text-gray-600">by {book.data.author}</p>

    {book.data.readYear && (
      <p class="text-sm italic">Read in {book.data.readYear}</p>
    )}

    {book.data.tags?.length && (
      <p class="mt-2 text-xs text-gray-500">
        Tags: {book.data.tags.join(", ")}
      </p>
    )}

    <hr class="my-6" />

    <div class="mt-6 prose max-w-none">
      <book.Component /> {/* ✅ This renders the MDX/Markdown body */}
    </div>
  </article>
</BaseLayout>
