---
import { PROFILE } from "../../content/profileData";

type Study = { category: string; title: string; institution?: string };

const CATEGORY_ORDER = ["Education", "Coursework", "Competition", "Independent Research"];

const groups = new Map<string, Study[]>();
for (const study of PROFILE.studies as Study[]) {
  const key = study.category ?? "Other";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(study);
}

const orderedGroups = [...CATEGORY_ORDER, ...[...groups.keys()].filter((k) => !CATEGORY_ORDER.includes(k))]
  .filter((k) => groups.has(k))
  .map((k) => [k, groups.get(k)!] as const);
---

<div class="mt-1 flex flex-col gap-3 text-sm">
  {orderedGroups.map(([category, items]) => (
    <div>
      <h4 class="text-xs uppercase tracking-wide font-semibold text-muted-foreground mb-1">
        {category}
      </h4>
      <ul class="flex flex-col gap-0.5">
        {items.map((study) => (
          <li class="leading-snug">
            <span class="font-medium">{study.title}</span>
            {study.institution && (
              <span class="text-muted-foreground"> · {study.institution}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
