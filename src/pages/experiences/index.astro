---
import { getCollection } from "astro:content";
import { formateLocalMonth } from "../../lib/utils";
import { Badge } from "../../components/ui/badge";
import IndexPageLayout from "../../layouts/IndexPageLayout.astro";
import { TableCell, TableRow, Table, TableBody } from "../../components/ui/table";
import { ArrowRight } from "lucide-react";

const experiences = await getCollection('experiences');

experiences.sort((a, b) => {
  return new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime();
});
---
<IndexPageLayout title="Experiences"
                 description="Places I have worked and the roles I have held."
                 subTitle="Experiences">
  {experiences.length === 0 ? (
    <p class="text-sm text-muted-foreground italic">Work and research experience coming soon.</p>
  ) : (
    <Table>
      <TableBody>
        {experiences.map((entry) => (
          <TableRow key={entry.slug}>
            <TableCell className="font-medium">
              <div class="flex flex-col gap-1 min-w-20">
                <a
                  href={'/experiences/' + entry.slug}
                  class="font-semibold text-primary hover:font-extrabold"
                >
                  {entry.data.title}
                </a>
                <div class="mb-4 text-sm">
                  {formateLocalMonth(entry.data.startDate)}
                  {entry.data.endDate ? ` - ${formateLocalMonth(entry.data.endDate)}` : ' - Present'}
                </div>
              </div>
            </TableCell>
            <TableCell>
              <div class="ml-4 flex p-2 flex-col gap-2 text-sm max-w-lg min-w-16">
                {entry.data.company}
                <div class="flex gap-1 flex-wrap">
                  {(entry.data.tags ?? []).map((i) => (
                    <a href={`/tags/${i}`}>
                      <Badge className="truncate">{i}</Badge>
                    </a>
                  ))}
                </div>
              </div>
            </TableCell>
            <TableCell>
              <a href={'/experiences/' + entry.slug}>
                <ArrowRight/>
              </a>
            </TableCell>
          </TableRow>
        ))}
      </TableBody>
    </Table>
  )}
</IndexPageLayout>
