---
import { getCollection } from "astro:content";
import { Button } from '../ui/button'
import { formateLocalMonth } from "../../lib/utils";

let experiences = await getCollection('experiences');

experiences.sort((a, b) => {
  return new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime();
});

experiences = experiences.slice(0, 3);
---

<div class="mt-2 space-y-4">
  {experiences.length === 0 ? (
    <p class="text-sm text-muted-foreground italic">Coming soon.</p>
  ) : (
    <>
      {experiences.map((exp) => (
        <div>
          <h4 class="text-md font-medium">{exp.data.title}</h4>
          <a class="text-sm text-primary hover:underline" href={'/experiences/' + exp.slug}>
            {exp.data.company}
          </a>
          <p class="text-sm text-gray-600">
            {formateLocalMonth(exp.data.startDate)}
            {exp.data.endDate ? ` - ${formateLocalMonth(exp.data.endDate)}` : ' - Present'}
          </p>
        </div>
      ))}
      <a href="/experiences">
        <Button variant="link" className="pl-0">View More</Button>
      </a>
    </>
  )}
</div>
