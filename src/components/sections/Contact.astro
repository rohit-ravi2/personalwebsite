---
import Card from '../Card.astro'
import { PROFILE } from "../../content/profileData";
---

<Card>
  <div class="h-full">
    <!-- Contact Info -->
    <address class="mt-4 flex flex-col not-italic">
      <h2 class="text-gray-500 text-lg font-semibold">Contact Me</h2>
      <p class="text-lg text-foreground">{PROFILE.email}</p>
      <p class="text-md mt-1">{PROFILE.location}</p>
    </address>

    <!-- Contact Form -->
    <div class="mt-6">
      <h2 class="text-gray-500 text-lg font-semibold mb-2">Send me a message</h2>
      <form 
        action={`mailto:${PROFILE.email}`} 
        method="POST" 
        enctype="text/plain"
        class="flex flex-col gap-3 max-w-md"
      >
        <label for="name" class="text-sm text-gray-700">Name</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required
          class="rounded-md border border-gray-300 p-2 focus:outline-none focus:ring-2 focus:ring-accent"
        />

        <label for="email" class="text-sm text-gray-700">Email</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required
          class="rounded-md border border-gray-300 p-2 focus:outline-none focus:ring-2 focus:ring-accent"
        />

        <label for="message" class="text-sm text-gray-700">Message</label>
        <textarea 
          id="message" 
          name="message" 
          rows="4" 
          required
          class="rounded-md border border-gray-300 p-2 focus:outline-none focus:ring-2 focus:ring-accent"
        ></textarea>

        <button 
          type="submit"
          class="mt-2 rounded-lg bg-primary px-4 py-2 font-medium text-white hover:bg-primary/80 transition"
        >
          Send
        </button>
      </form>
    </div>
  </div>
</Card>
