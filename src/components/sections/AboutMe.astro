---
import { getAndGroupUniqueTags } from "../../lib/utils";
import { PROFILE } from "../../content/profileData";

const tagsMap = await getAndGroupUniqueTags();
const skills = PROFILE.skills;
---

<div class="flex flex-col gap-2 animate-appear">
  <p class="text-md font-medium mb-1">
    {PROFILE.headLine}
  </p>

  <p class="text-sm font-light mb-1">
    {PROFILE.headLine2}
  </p>

  <hr/>

  <p class="text-sm font-light">
    Areas I work in:
  </p>
  <ul class="list-inside list-disc text-sm">
    {skills.map((skill) => (
      tagsMap.has(skill) ? (
        <li>
          <a href={`/tags/${skill}`} class="hover:font-bold">{skill}</a>
        </li>
      ) : (
        <li><span>{skill}</span></li>
      )
    ))}
  </ul>

  <p class="text-sm font-light">
    More on <a href="/projects" class="underline hover:font-bold">Projects</a> and <a href="/experiences" class="underline hover:font-bold">Experience</a>.
  </p>
</div>
